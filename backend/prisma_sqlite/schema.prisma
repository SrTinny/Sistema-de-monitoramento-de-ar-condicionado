generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  airConditioners AirConditioner[]
  operations      Operation[]
}

model AirConditioner {
  id             String     @id @default(cuid())
  deviceId       String     @unique
  name           String
  room           String
  status         String     @default("offline")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  humidity       Float?
  pendingCommand String?
  temperature    Float?
  setpoint       Float?     @default(22)
  lastHeartbeat  DateTime?
  irSignals      Json?
  irSignalLigar  String?
  irSignalDesligar String?
  irSignalTempUp String?
  irSignalTempDown String?
  irLearnState   String?
  irLearnButton  String?
  irLearnRaw     String?
  irLearnMessage String?
  irLearnUpdatedAt DateTime?
  ownerId        String?
  owner          User?      @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  schedules      Schedule[]
  operations     Operation[]

  @@index([lastHeartbeat])
}

model Operation {
  id               String     @id @default(cuid())
  type             String
  payload          Json?
  createdAt        DateTime   @default(now())
  userId           String?
  user             User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  airConditionerId String?
  airConditioner   AirConditioner? @relation(fields: [airConditionerId], references: [id], onDelete: Cascade)
}

model Schedule {
  id               String         @id @default(cuid())
  scheduledAt      DateTime?
  action           ScheduleAction
  status           ScheduleStatus @default(PENDENTE)
  createdAt        DateTime       @default(now())
  airConditionerId String
  airConditioner   AirConditioner @relation(fields: [airConditionerId], references: [id], onDelete: Cascade)
  isRecurring      Boolean        @default(false)
  recurringTime    String?
}

enum Role {
  USER
  ADMIN
}

enum ScheduleAction {
  LIGAR
  DESLIGAR
  AJUSTAR_TEMPERATURA
}

enum ScheduleStatus {
  PENDENTE
  EXECUTADO
  CANCELADO
}
